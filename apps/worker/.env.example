PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Firebase Admin
FIREBASE_ADMIN_PROJECT_ID=ssamsearch-dev
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@ssamsearch-dev.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# KMS
USE_KMS_MOCK=true
KMS_MOCK_KEY=this-is-a-32-byte-mock-key-for-dev!

# Gemini
GEMINI_API_KEY=

# 내부 인증 토큰
WORKER_INTERNAL_TOKEN=local-dev-token-change-in-production

# Playwright
# 개발: 시스템 Chromium 사용
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# 테스트 계정 (절대 커밋 금지)
# TEST_INDISCHOOL_USER=
# TEST_INDISCHOOL_PASS=
# TEST_ISCREAM_USER=
# TEST_ISCREAM_PASS=
# TEST_TEACHERVILLE_USER=
# TEST_TEACHERVILLE_PASS=
# TEST_TSHERPA_USER=
# TEST_TSHERPA_PASS=
# TEST_EDUNET_USER=
# TEST_EDUNET_PASS=
