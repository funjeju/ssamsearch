# === Firebase (클라이언트) ===
NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ssamsearch-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ssamsearch-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ssamsearch-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# 에뮬레이터 사용 (개발)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# === Firebase Admin (서버 전용) ===
FIREBASE_ADMIN_PROJECT_ID=ssamsearch-dev
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@ssamsearch-dev.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Upstash Redis ===
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# === Google Cloud KMS ===
# 개발은 mock 사용
USE_KMS_MOCK=true
KMS_MOCK_KEY=this-is-a-32-byte-mock-key-for-dev!

# 운영
# USE_KMS_MOCK=false
# GCP_KMS_PROJECT_ID=ssamsearch-prod
# GCP_KMS_LOCATION=asia-northeast3
# GCP_KMS_KEYRING=ssamsearch-keyring
# GCP_KMS_KEY=user-credential-master-key

# === SMS OTP ===
# 개발: 콘솔 출력 모드 (SMS 실제 발송 안 함)
SMS_PROVIDER=console

# 운영
# SMS_PROVIDER=nhn
# NHN_CLOUD_APP_KEY=
# NHN_CLOUD_SECRET_KEY=
# NHN_CLOUD_SENDER_PHONE=

# === Gemini AI ===
GEMINI_API_KEY=

# === 워커 연동 ===
WORKER_URL=http://localhost:8080
WORKER_INTERNAL_TOKEN=local-dev-token-change-in-production
